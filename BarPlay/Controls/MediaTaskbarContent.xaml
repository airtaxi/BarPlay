<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="BarPlay.Controls.MediaTaskbarContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:BarPlay.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ex="using:WinUIEx"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="48"
    d:DesignWidth="380"
    Loaded="OnLoaded"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="TransportButtonStyle" TargetType="Button">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="FlyoutTransportButtonStyle" TargetType="Button">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Button
        x:Uid="MediaInfoButton"
        Margin="0,0,4,0"
        Padding="4"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        Background="Transparent"
        BorderBrush="Transparent"
        CornerRadius="4">
        <Button.Flyout>
            <Flyout
                Opened="OnFlyoutOpened"
                Placement="Top"
                ShouldConstrainToRootBounds="False">
                <Flyout.FlyoutPresenterStyle>
                    <Style TargetType="FlyoutPresenter">
                        <Setter Property="MaxWidth" Value="440" />
                        <Setter Property="MinWidth" Value="360" />
                        <Setter Property="Padding" Value="16" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                        <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
                        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                    </Style>
                </Flyout.FlyoutPresenterStyle>

                <StackPanel
                    Width="400"
                    KeyboardAcceleratorPlacementMode="Hidden"
                    Spacing="12">
                    <StackPanel.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Space" Invoked="OnFlyoutSpaceKeyboardAcceleratorInvoked" />
                    </StackPanel.KeyboardAccelerators>
                    <!--  No session state  -->
                    <TextBlock
                        x:Uid="NoMediaText"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind ViewModel.HasNoSession, Mode=OneWay}" />

                    <!--  Normal state  -->
                    <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.HasSession, Mode=OneWay}">
                        <!--  Album art + Title + Artist  -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Width="72"
                                Height="72"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8">
                                <Grid>
                                    <FontIcon
                                        FontSize="32"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE93C;" />
                                    <Image Source="{x:Bind ViewModel.Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                                </Grid>
                            </Border>
                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Spacing="2">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!--  Settings Button  -->
                            <Button
                                Grid.Column="1"
                                Width="28"
                                Height="28"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                BorderBrush="Transparent">
                                <Button.Flyout>
                                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                        <ToggleMenuFlyoutItem
                                            x:Name="AutoStartToggleMenuFlyoutItem"
                                            x:Uid="AutoStartToggleMenuFlyoutItem"
                                            Command="{x:Bind ViewModel.ToggleAutoStartCommand}"
                                            CommandParameter="{x:Bind AutoStartToggleMenuFlyoutItem}" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem x:Uid="ExitMenuItem" Command="{x:Bind ViewModel.ExitCommand}" />
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon FontSize="16" Glyph="&#xE713;" />
                            </Button>
                        </Grid>

                        <!--  Seek slider  -->
                        <Slider
                            ManipulationCompleted="OnSliderManipulationCompleted"
                            ManipulationMode="All"
                            ManipulationStarted="OnSliderManipulationStarted"
                            Maximum="{x:Bind ViewModel.EndTimeTicks, Mode=OneWay}"
                            Minimum="0"
                            StepFrequency="10000000"
                            Visibility="{x:Bind ViewModel.HasTimeline, Mode=OneWay}"
                            Value="{x:Bind ViewModel.PositionTicks, Mode=TwoWay}">
                            <Slider.ThumbToolTipValueConverter>
                                <converters:SeekSliderThumbToolTipConverter />
                            </Slider.ThumbToolTipValueConverter>
                        </Slider>

                        <!--  Time labels  -->
                        <Grid Margin="0,-12,0,0" Visibility="{x:Bind ViewModel.HasTimeline, Mode=OneWay}">
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.PositionText, Mode=OneWay}"
                                TextLineBounds="Tight" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.EndTimeText, Mode=OneWay}"
                                TextLineBounds="Tight" />
                        </Grid>

                        <!--  Transport buttons  -->
                        <StackPanel
                            Margin="0,-24,0,0"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">

                            <!--  Previous  -->
                            <Button
                                x:Uid="PreviousButton"
                                Command="{x:Bind ViewModel.SkipPreviousCommand}"
                                IsEnabled="{x:Bind ViewModel.CanSkipPrevious, Mode=OneWay}"
                                Style="{StaticResource FlyoutTransportButtonStyle}">
                                <FontIcon FontSize="20" Glyph="&#xE76B;" />
                            </Button>

                            <!--  Play / Pause  -->
                            <Button
                                x:Name="FlyoutPlayPauseButton"
                                x:Uid="PlayPauseButton"
                                Command="{x:Bind ViewModel.TogglePlayPauseCommand}"
                                IsEnabled="{x:Bind ViewModel.CanPlayPause, Mode=OneWay}"
                                Style="{StaticResource FlyoutTransportButtonStyle}">
                                <Grid>
                                    <FontIcon
                                        FontSize="20"
                                        Glyph="&#xE768;"
                                        Visibility="{x:Bind ViewModel.IsNotPlaying, Mode=OneWay}" />
                                    <FontIcon
                                        FontSize="20"
                                        Glyph="&#xE769;"
                                        Visibility="{x:Bind ViewModel.IsPlaying, Mode=OneWay}" />
                                </Grid>
                            </Button>

                            <!--  Next  -->
                            <Button
                                x:Uid="NextButton"
                                Command="{x:Bind ViewModel.SkipNextCommand}"
                                IsEnabled="{x:Bind ViewModel.CanSkipNext, Mode=OneWay}"
                                Style="{StaticResource FlyoutTransportButtonStyle}">
                                <FontIcon FontSize="20" Glyph="&#xE76C;" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Flyout>
        </Button.Flyout>

        <Grid ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!--  Button content: thumbnail + text  -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!--  Thumbnail  -->
                <Border
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="4">
                    <Grid>
                        <FontIcon
                            FontSize="18"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE93C;" />
                        <Image Source="{x:Bind ViewModel.Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                    </Grid>
                </Border>

                <!--  Text  -->
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="0">
                    <!--  Normal: Title + Description  -->
                    <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasSession, Mode=OneWay}">
                        <TextBlock
                            FontSize="12"
                            Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                            TextLineBounds="Tight"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            FontSize="10"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                            TextLineBounds="Tight"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <!--  Empty state  -->
                    <TextBlock
                        x:Uid="NoMediaShortText"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind ViewModel.HasNoSession, Mode=OneWay}" />
                </StackPanel>
            </Grid>

            <!--  Transport buttons  -->
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="2">

                <!--  Previous  -->
                <Button
                    x:Uid="PreviousButton"
                    Command="{x:Bind ViewModel.SkipPreviousCommand}"
                    IsEnabled="{x:Bind ViewModel.CanSkipPrevious, Mode=OneWay}"
                    Style="{StaticResource TransportButtonStyle}">
                    <FontIcon FontSize="16" Glyph="&#xE76B;" />
                </Button>

                <!--  Play / Pause  -->
                <Button
                    x:Uid="PlayPauseButton"
                    Command="{x:Bind ViewModel.TogglePlayPauseCommand}"
                    IsEnabled="{x:Bind ViewModel.CanPlayPause, Mode=OneWay}"
                    Style="{StaticResource TransportButtonStyle}">
                    <Grid>
                        <FontIcon
                            FontSize="16"
                            Glyph="&#xE768;"
                            Visibility="{x:Bind ViewModel.IsNotPlaying, Mode=OneWay}" />
                        <FontIcon
                            FontSize="16"
                            Glyph="&#xE769;"
                            Visibility="{x:Bind ViewModel.IsPlaying, Mode=OneWay}" />
                    </Grid>
                </Button>

                <!--  Next  -->
                <Button
                    x:Uid="NextButton"
                    Command="{x:Bind ViewModel.SkipNextCommand}"
                    IsEnabled="{x:Bind ViewModel.CanSkipNext, Mode=OneWay}"
                    Style="{StaticResource TransportButtonStyle}">
                    <FontIcon FontSize="16" Glyph="&#xE76C;" />
                </Button>
            </StackPanel>
        </Grid>
    </Button>
</UserControl>
